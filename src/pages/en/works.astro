---
import WorksGrid from '@/components/WorksGrid.astro';
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
	title="Works"
	activeNav="works"
	description="Side projects, open-source repos, and experiments by Abraham Yin"
>
	<div class="works-page">
		<p class="works-page-intro">
			A few things I have built. Add a new card by editing <code>src/data/works/entries.json</code> — no
			component changes needed.
		</p>
		<WorksGrid />
	</div>
</PageLayout>
