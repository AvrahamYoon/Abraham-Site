---
import WorksGrid from '@/components/WorksGrid.astro';
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
	title="作品"
	activeNav="works"
	description="幽靈的 side project、開源倉庫與實驗性小工具"
>
	<div class="works-page">
		<p class="works-page-intro">
			一些做過的小項目。新作品只要在 <code>src/data/works/entries.json</code> 加一筆資料即可，不用改元件。
		</p>
		<WorksGrid />
	</div>
</PageLayout>
