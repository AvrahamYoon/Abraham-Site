---
import BaseLayout from './BaseLayout.astro';
import ProfileCard from '@/components/ProfileCard.astro';
import SidebarNav from '@/components/SidebarNav.astro';
import type { NavId } from '@/data/nav';
import { getSiteMeta } from '@/data/site';
import { getLocale } from '@/lib/locale';

interface Props {
	title: string;
	activeNav: NavId;
	description?: string;
}

const locale = getLocale(Astro.currentLocale);
const meta = getSiteMeta(locale);
const { title, activeNav, description } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass="page-bg min-h-screen">
	<div class="mx-auto flex min-h-screen max-w-6xl flex-col px-4 py-8 lg:py-10">
		<div class="grid flex-1 gap-8 lg:grid-cols-[minmax(0,17rem)_1fr] lg:items-start lg:gap-10">
			<aside class="space-y-4 lg:sticky lg:top-8">
				<div transition:persist="profile-card">
					<ProfileCard variant="sidebar" />
				</div>
				<SidebarNav activeId={activeNav} />
			</aside>

			<div class="flex min-w-0 flex-col gap-6">
				<header class="shrink-0" transition:animate="none">
					<h1 class="page-title">{title}</h1>
				</header>

				<main
					class="panel min-h-[28rem] flex-1 p-6 sm:min-h-[32rem] sm:p-10"
					transition:animate="none"
				>
					<slot />
				</main>
			</div>
		</div>

		<footer class="mt-12 shrink-0 text-center text-xs text-ink-muted">
			<p>{meta.copyright}</p>
		</footer>
	</div>
</BaseLayout>
