{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"framework": "astro",
	"buildCommand": "npm run build",
	"outputDirectory": "dist",
	"redirects": [
		{
			"source": "/",
			"destination": "/en/",
			"permanent": false
		},
		{
			"source": "/zh-TW",
			"destination": "/zh-tw",
			"permanent": true
		},
		{
			"source": "/zh-TW/:path*",
			"destination": "/zh-tw/:path*",
			"permanent": true
		}
	],
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/favicon.(ico|svg)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400"
				}
			]
		}
	]
}
