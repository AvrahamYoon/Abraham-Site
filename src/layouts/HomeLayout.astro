---
import BaseLayout from './BaseLayout.astro';
import NavList from '@/components/NavList.astro';
import ProfileCard from '@/components/ProfileCard.astro';
import { getSiteMeta, site } from '@/data/site';
import { getLocale } from '@/lib/locale';

const locale = getLocale(Astro.currentLocale);
const meta = getSiteMeta(locale);
---

<BaseLayout bodyClass="home-bg min-h-screen">
	<main
		class="page-fade mx-auto flex min-h-screen w-full max-w-lg flex-col justify-center px-4 pt-[calc(4rem+env(safe-area-inset-top,0px))] pb-[max(4rem,env(safe-area-inset-bottom,0px))] sm:py-20"
	>
		<div class="mx-auto w-full max-w-lg space-y-8 text-center">
			<ProfileCard />
			<NavList />

			<footer class="space-y-1 pt-4 text-center text-xs text-ink-muted">
				<p>{meta.copyright}</p>
				{site.icp ? <p>{site.icp}</p> : null}
			</footer>
		</div>
	</main>
</BaseLayout>
